{
  "compilerOptions": {
    "target"                           : "ES2023",
    "module"                           : "NodeNext",
    "moduleResolution"                 : "NodeNext",
    "strict"                           : true,
    "noUncheckedIndexedAccess"         : true,
    "exactOptionalPropertyTypes"       : true,
    "noImplicitReturns"                : true,
    "noFallthroughCasesInSwitch"       : true,
    "noImplicitOverride"               : true,
    "declaration"                      : true,
    "declarationMap"                   : true,
    "sourceMap"                        : true,
    "outDir"                           : "./dist",
    "rootDir"                          : "./src",
    "skipLibCheck"                     : true
  },
  "include"  : ["src/**/*"],
  "exclude"  : ["node_modules", "dist", ".github"]
}
